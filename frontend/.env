# Backend host without trailing slash
VITE_API_BASE_URL=http://api.toroongo.com

# API path prefix appended to VITE_API_BASE_URL
VITE_API_PREFIX=/api

# Optional storage namespace (used for fallback auth keys)
VITE_STORAGE_PREFIX=toroongo

# Optional explicit auth key overrides
VITE_AUTH_TOKEN_STORAGE_KEY=toroongo_token
VITE_AUTH_USER_STORAGE_KEY=toroongo_user

# Set true only when using cookie-based auth (Sanctum SPA mode)
VITE_USE_CREDENTIALS=false