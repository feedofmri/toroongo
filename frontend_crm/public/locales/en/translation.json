    "shipping": {
        "title": "Shipping info",
        "subtitle": "Shipping is set and managed by individual sellers.",
        "sellerManaged": {
            "title": "Seller-Managed Shipping",
            "desc": "Toroongo is a marketplace where each seller is responsible for setting their own shipping rates and delivery methods. Shipping costs and estimated delivery times are determined by the seller and will be clearly displayed on the product page and during checkout."
        },
        "cost": {
            "title": "Shipping Costs",
            "desc": "Shipping fees vary depending on the seller, the item weight, and your delivery location. Some sellers may offer free shipping for orders above a certain amount, while others may have flat rates or calculated costs."
        },
        "tracking": {
            "title": "Order Tracking",
            "desc": "Once your order is shipped, the seller will provide a tracking number. You can monitor your shipment through the dashboard under \"My Orders.\" If you have any questions about your delivery, you can message the seller directly."
        },
        "global": {
            "title": "Global & Regional Delivery",
            "desc": "While Toroongo has a strong presence in core markets like Bangladesh, Nepal, India, UAE, Indonesia, and Malaysia, our sellers can ship to almost any location globally. Please check the seller's individual store policies for international shipping availability."
        }
    },
