        "faq": [
            {
                "q": "How do I track my order?",
                "a": "Go to My Account > My Orders to see real-time tracking information for all your purchases."
            },
            {
                "q": "What is the return policy?",
                "a": "Most items can be returned within 30 days of delivery. Check the seller's store policies for specific details."
            },
            {
                "q": "How do I become a seller?",
                "a": "Click 'Sell on Toroongo' and create a free seller account. You can start listing products immediately."
            },
            {
                "q": "Is my payment information secure?",
                "a": "Absolutely. All payments are processed through encrypted, PCI-compliant systems. We never store your full card details."
            },
            {
                "q": "How do I contact a seller?",
                "a": "Go to the seller's store page and use the 'Message' feature, or find it in your Account Messages section."
            },
            {
                "q": "What happens if I receive a defective item?",
                "a": "Open a dispute through your order page and our team will help resolve it within 48 hours."
            }
        ]
