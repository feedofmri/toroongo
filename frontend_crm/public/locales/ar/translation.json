                {
                    "title": "١. المعلومات التي نجمعها",
                    "content": "نجمع المعلومات التي تقدمها مباشرة (الاسم، البريد الإلكتروني) بالإضافة إلى بيانات الاستخدام لتحسين تجربتك."
                },
                {
                    "title": "٢. كيف نستخدم معلوماتك",
                    "content": "نستخدم بياناتك لمعالجة الطلبات وتخصيص تجربة التسوق الخاصة بك ومنع الاحتيال."
                },
                {
                    "title": "٣. مشاركة البيانات",
                    "content": "نشارك المعلومات الضرورية مع البائعين لتنفيذ الطلبات. نحن لا نبيع البيانات الشخصية لأطراف ثالثة."
                },
                {
                    "title": "٤. أمن البيانات",
                    "content": "ننفذ تدابير أمنية معيارية في الصناعة بما في ذلك التشفير لحماية معلوماتك."
                },
                {
                    "title": "٥. حقوقك",
                    "content": "يمكنك طلب الوصول إلى بياناتك الشخصية أو تصحيحها أو حذفها في أي وقت."
                }
            ]
        }
